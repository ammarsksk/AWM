# Copy this file to `.env.local` and fill in exactly one provider key.
# `.env.local` is read automatically by the local demos and provider helpers.

# Google Gemini OpenAI-compatible API
GEMINI_API_KEY=

# Optional: override only if needed; otherwise the code uses Google's default.
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Google Cloud Vertex AI OpenAI-compatible API
# Use this when you want Google Cloud credits / billing instead of AI Studio free quota.
# Leave GEMINI_API_KEY empty/commented if using Vertex.
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=global
# Optional alternative to Application Default Credentials:
# VERTEX_ACCESS_TOKEN=

# Groq OpenAI-compatible API
# GROQ_API_KEY=

# OpenRouter OpenAI-compatible API
# OPENROUTER_API_KEY=

# NVIDIA hosted NIM
# NVIDIA_NIM_API_KEY=
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
