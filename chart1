\definecolor{inputblue}{RGB}{219,234,254}
\definecolor{processblue}{RGB}{224,242,254}
\definecolor{memorygreen}{RGB}{220,252,231}
\definecolor{rankpurple}{RGB}{237,233,254}
\definecolor{warnred}{RGB}{254,226,226}
\definecolor{evalorange}{RGB}{255,237,213}
\definecolor{linegray}{RGB}{71,85,105}
\definecolor{textgray}{RGB}{30,41,59}

\begin{tikzpicture}[
  font=\sffamily,
  >={Latex[length=2.5mm,width=1.8mm]},
  node distance=6mm and 8mm,
  box/.style={
    rectangle, rounded corners=3pt, very thick, align=center,
    text width=52mm, minimum height=11mm, inner sep=4pt,
    text=textgray, font=\sffamily\footnotesize, draw=#1!78!black, fill=#1
  },
  smallbox/.style={
    rectangle, rounded corners=3pt, thick, align=center,
    text width=38mm, minimum height=10mm, inner sep=3pt,
    text=textgray, font=\sffamily\scriptsize, draw=#1!78!black, fill=#1
  },
  decision/.style={
    diamond, aspect=2.2, very thick, align=center,
    text width=36mm, inner sep=2pt, text=textgray,
    font=\sffamily\footnotesize, draw=#1!80!black, fill=#1
  },
  flow/.style={->, very thick, draw=linegray},
  data/.style={->, thick, dashed, draw=linegray},
  neg/.style={->, thick, dashed, draw=red!70!black}
]

\node[box=inputblue] (state) {Current goal and page state\\[-1mm]\scriptsize Live browser observation remains authoritative};
\node[smallbox=rankpurple, below left=of state] (advice) {Accepted procedure cards};
\node[smallbox=warnred, below right=of state] (warnings) {Negative warnings and avoid rules};
\node[box=processblue, below=15mm of state] (prompt) {Prompt composer\\[-1mm]\scriptsize Goal, page, history, memory, and warnings};
\node[box=processblue, below=of prompt] (policy) {Action policy chooses grounded browser action};
\node[box=processblue, below=of policy] (browser) {Playwright/BrowserGym executes click, fill, scroll, navigate, or final answer};
\node[decision=evalorange, below=of browser] (outcome) {Successful outcome?};
\node[box=memorygreen, below left=9mm and 7mm of outcome] (success) {Summarize successful trace\\[-1mm]\scriptsize evidence, actions, checks, answer format};
\node[box=warnred, below right=9mm and 7mm of outcome] (failure) {Diagnose failed trace\\[-1mm]\scriptsize wrong assumption, missing evidence, unsafe reuse};
\node[box=memorygreen, below=of success] (posstore) {Write reusable procedure and refreshed embedding};
\node[box=warnred, below=of failure] (negstore) {Write negative memory and graph failure links};
\node[box=rankpurple, below=18mm of outcome] (next) {Next task or next page state retrieves from updated memory};

\draw[flow] (state) -- (prompt);
\draw[data] (advice) -- (prompt);
\draw[neg] (warnings) -- (prompt);
\draw[flow] (prompt) -- (policy);
\draw[flow] (policy) -- (browser);
\draw[flow] (browser) -- (outcome);
\draw[flow] (outcome) -- node[left, font=\scriptsize] {yes} (success);
\draw[neg] (outcome) -- node[right, font=\scriptsize] {no} (failure);
\draw[flow] (success) -- (posstore);
\draw[neg] (failure) -- (negstore);
\draw[data] (posstore.south) |- (next.west);
\draw[data] (negstore.south) |- (next.east);

\end{tikzpicture}

